<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Wanderlust – Find your perfect stay</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet"/>
  <link rel="stylesheet" href="/css/style.css" />
</head>
<body>

  <%# ── Navbar ── %>
  <nav class="navbar navbar-expand-lg wl-navbar">
    <div class="container">
      <a class="navbar-brand wl-brand" href="/listings">🌍 Wanderlust</a>
      <div class="ms-auto">
        <a href="/listings/new" class="btn btn-light btn-sm fw-semibold wl-btn-new">
          + New Listing
        </a>
      </div>
    </div>
  </nav>

  <%# ── Hero ── %>
  <div class="wl-hero">
    <div class="container text-center">
      <h1 class="wl-hero-title">Find your perfect stay</h1>
      <p class="wl-hero-sub">Discover unique homes, cabins, villas and more around the world.</p>
    </div>
  </div>

  <%# ── Flash messages ── %>
  <div class="container mt-3">
    <% if (success && success.length > 0) { %>
      <div class="alert alert-success alert-dismissible fade show" role="alert">
        <i>✅</i> <%= success %>
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
      </div>
    <% } %>
    <% if (error && error.length > 0) { %>
      <div class="alert alert-danger alert-dismissible fade show" role="alert">
        <i>⚠️</i> <%= error %>
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
      </div>
    <% } %>
  </div>

  <%# ── Category filters ── %>
  <div class="container mt-2 mb-1">
    <div class="wl-filters">
      <% const categories = ["All", "Beach", "Mountains", "Cities", "Islands", "Ski", "Cabins", "Other"]; %>
      <% const icons = { All:"🌐", Beach:"🏖️", Mountains:"⛰️", Cities:"🏙️", Islands:"🏝️", Ski:"⛷️", Cabins:"🌲", Other:"✨" }; %>
      <% for (let cat of categories) { %>
        <a
          href="/listings<%= cat === 'All' ? '' : '?category=' + cat %>"
          class="wl-filter-pill <%= activeCategory === cat ? 'active' : '' %>"
        >
          <span class="wl-filter-icon"><%= icons[cat] %></span>
          <%= cat %>
        </a>
      <% } %>
    </div>
  </div>

  <%# ── Listings grid ── %>
  <main class="container my-4">
    <% if (allListings.length === 0) { %>
      <div class="text-center py-5">
        <p class="fs-4">😕 No listings found.</p>
        <p class="text-muted">Try a different category or <a href="/listings/new" style="color:#ff385c;">add a new listing</a>.</p>
      </div>
    <% } else { %>
      <p class="text-muted small mb-3"><%= allListings.length %> listing<%= allListings.length !== 1 ? 's' : '' %> available</p>
      <div class="row row-cols-1 row-cols-sm-2 row-cols-md-3 row-cols-lg-4 g-4">
        <% for (let listing of allListings) { %>
          <div class="col">
            <a href="/listings/<%= listing._id %>" class="text-decoration-none text-dark">
              <div class="card h-100 border-0 wl-listing-card">

                <%# Category badge %>
                <div class="wl-badge-wrap">
                  <span class="wl-category-badge"><%= listing.category %></span>
                </div>

                <img
                  src="<%= listing.image.url %>"
                  class="card-img-top wl-card-img"
                  alt="<%= listing.title %>"
                  onerror="this.src='https://images.unsplash.com/photo-1501785888041-af3ef285b470?auto=format&fit=crop&w=800&q=60'"
                />
                <div class="card-body px-2 pb-2 pt-2">
                  <h6 class="card-title fw-semibold mb-1 wl-card-title"><%= listing.title %></h6>
                  <p class="card-text text-muted small mb-1">📍 <%= listing.location %>, <%= listing.country %></p>

                  <%# Star rating average %>
                  <% if (listing.reviews && listing.reviews.length > 0) { %>
                    <% const avg = (listing.reviews.reduce((sum, r) => sum + r.rating, 0) / listing.reviews.length).toFixed(1); %>
                    <p class="card-text small mb-1">
                      <span class="wl-star">★</span> <%= avg %>
                      <span class="text-muted">(<%= listing.reviews.length %>)</span>
                    </p>
                  <% } %>

                  <p class="card-text fw-semibold wl-price mb-0">
                    $<%= listing.price.toLocaleString("en-US") %>
                    <span class="text-muted fw-normal small">/ night</span>
                  </p>
                </div>
              </div>
            </a>
          </div>
        <% } %>
      </div>
    <% } %>
  </main>

  <%# ── Footer ── %>
  <footer class="wl-footer">
    <div class="container d-flex flex-column flex-md-row justify-content-between align-items-center">
      <span>Mandeep Sharma &nbsp;|&nbsp; &copy; 2025 Wanderlust. All rights reserved.</span>
      <div class="wl-footer-links mt-2 mt-md-0">
        <a href="#">Privacy</a>
        <a href="#">Terms</a>
        <a href="#">Support</a>
      </div>
    </div>
  </footer>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
