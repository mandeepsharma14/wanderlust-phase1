<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Wanderlust – <%= listing.title %></title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet"/>
  <link rel="stylesheet" href="/css/style.css" />
</head>
<body>

  <%# ── Navbar ── %>
  <nav class="navbar wl-navbar">
    <div class="container">
      <a class="navbar-brand wl-brand" href="/listings">🌍 Wanderlust</a>
      <div class="ms-auto">
        <a href="/listings/new" class="btn btn-light btn-sm fw-semibold wl-btn-new">
          + New Listing
        </a>
      </div>
    </div>
  </nav>

  <%# ── Flash messages ── %>
  <div class="container mt-3">
    <% if (success && success.length > 0) { %>
      <div class="alert alert-success alert-dismissible fade show" role="alert">
        ✅ <%= success %>
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
      </div>
    <% } %>
    <% if (error && error.length > 0) { %>
      <div class="alert alert-danger alert-dismissible fade show" role="alert">
        ⚠️ <%= error %>
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
      </div>
    <% } %>
  </div>

  <main class="container my-4" style="max-width:900px;">

    <%# Back link %>
    <a href="/listings" class="wl-back-link d-inline-block mb-3">← Back to listings</a>

    <%# Hero image %>
    <img
      src="<%= listing.image.url %>"
      alt="<%= listing.title %>"
      class="w-100 rounded-3 mb-4 wl-show-img"
      onerror="this.src='https://images.unsplash.com/photo-1501785888041-af3ef285b470?auto=format&fit=crop&w=800&q=60'"
    />

    <%# Title & meta row %>
    <div class="d-flex flex-wrap justify-content-between align-items-start gap-2 mb-1">
      <div>
        <h2 class="fw-bold mb-1"><%= listing.title %></h2>
        <p class="text-muted mb-0">
          📍 <%= listing.location %>, <%= listing.country %>
          &nbsp;·&nbsp;
          <span class="wl-category-badge"><%= listing.category %></span>
        </p>
      </div>
      <div class="text-md-end">
        <p class="fs-4 fw-bold wl-price mb-0">
          $<%= listing.price.toLocaleString("en-US") %>
          <span class="fs-6 fw-normal text-muted">/ night</span>
        </p>
        <% if (listing.reviews && listing.reviews.length > 0) { %>
          <% const avg = (listing.reviews.reduce((sum, r) => sum + r.rating, 0) / listing.reviews.length).toFixed(1); %>
          <p class="mb-0 small">
            <span class="wl-star">★</span> <strong><%= avg %></strong>
            <span class="text-muted">· <%= listing.reviews.length %> review<%= listing.reviews.length !== 1 ? 's' : '' %></span>
          </p>
        <% } %>
      </div>
    </div>

    <hr/>

    <%# Description %>
    <p class="text-secondary lh-lg"><%= listing.description %></p>

    <hr/>

    <%# Action buttons %>
    <div class="d-flex gap-2 mb-5">
      <a href="/listings/<%= listing._id %>/edit" class="btn btn-outline-secondary btn-sm">
        ✏️ Edit listing
      </a>
      <form method="POST" action="/listings/<%= listing._id %>?_method=DELETE" class="d-inline">
        <button
          class="btn btn-outline-danger btn-sm"
          onclick="return confirm('Are you sure you want to delete this listing?')"
        >
          🗑️ Delete listing
        </button>
      </form>
    </div>

    <%# ── Reviews section ── %>
    <h4 class="fw-bold mb-3">
      Reviews
      <% if (listing.reviews && listing.reviews.length > 0) { %>
        <% const avg = (listing.reviews.reduce((sum, r) => sum + r.rating, 0) / listing.reviews.length).toFixed(1); %>
        <span class="fs-6 fw-normal text-muted ms-2">
          <span class="wl-star">★</span> <%= avg %> average
        </span>
      <% } %>
    </h4>

    <%# Existing reviews %>
    <% if (!listing.reviews || listing.reviews.length === 0) { %>
      <p class="text-muted mb-4">No reviews yet. Be the first to leave one!</p>
    <% } else { %>
      <div class="row g-3 mb-4">
        <% for (let review of listing.reviews) { %>
          <div class="col-12 col-md-6">
            <div class="wl-review-card">
              <div class="d-flex justify-content-between align-items-center mb-1">
                <div class="wl-review-stars">
                  <% for (let i = 1; i <= 5; i++) { %>
                    <span class="<%= i <= review.rating ? 'wl-star' : 'wl-star-empty' %>">★</span>
                  <% } %>
                </div>
                <form method="POST" action="/listings/<%= listing._id %>/reviews/<%= review._id %>?_method=DELETE">
                  <button class="btn btn-link btn-sm p-0 text-danger wl-review-delete" title="Delete review">✕</button>
                </form>
              </div>
              <p class="mb-1 small text-secondary"><%= review.comment || "No comment provided." %></p>
              <p class="mb-0 text-muted" style="font-size:11px;">
                <%= new Date(review.createdAt).toLocaleDateString("en-US", { year:"numeric", month:"short", day:"numeric" }) %>
              </p>
            </div>
          </div>
        <% } %>
      </div>
    <% } %>

    <%# Add review form %>
    <div class="wl-review-form-card">
      <h5 class="fw-semibold mb-3">Leave a Review</h5>
      <form method="POST" action="/listings/<%= listing._id %>/reviews" novalidate class="needs-validation">

        <div class="mb-3">
          <label class="form-label fw-semibold">Rating</label>
          <div class="wl-star-picker" id="starPicker">
            <% for (let i = 1; i <= 5; i++) { %>
              <span class="wl-star-btn" data-value="<%= i %>">★</span>
            <% } %>
          </div>
          <input type="hidden" name="review[rating]" id="ratingInput" required />
          <div class="form-text text-muted small">Click a star to select your rating.</div>
        </div>

        <div class="mb-3">
          <label class="form-label fw-semibold">Comment</label>
          <textarea
            name="review[comment]"
            class="form-control"
            rows="3"
            placeholder="Share your experience..."
          ></textarea>
        </div>

        <button type="submit" class="btn wl-btn-primary">Submit Review</button>
      </form>
    </div>

  </main>

  <%# ── Footer ── %>
  <footer class="wl-footer mt-5">
    <div class="container d-flex flex-column flex-md-row justify-content-between align-items-center">
      <span>Mandeep Sharma &nbsp;|&nbsp; &copy; 2025 Wanderlust. All rights reserved.</span>
      <div class="wl-footer-links mt-2 mt-md-0">
        <a href="#">Privacy</a>
        <a href="#">Terms</a>
        <a href="#">Support</a>
      </div>
    </div>
  </footer>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
  <script>
    // Interactive star picker
    const stars = document.querySelectorAll('.wl-star-btn');
    const ratingInput = document.getElementById('ratingInput');

    stars.forEach(star => {
      star.addEventListener('click', () => {
        const val = parseInt(star.dataset.value);
        ratingInput.value = val;
        stars.forEach((s, i) => {
          s.classList.toggle('active', i < val);
        });
      });
      star.addEventListener('mouseover', () => {
        const val = parseInt(star.dataset.value);
        stars.forEach((s, i) => s.classList.toggle('hover', i < val));
      });
      star.addEventListener('mouseout', () => {
        stars.forEach(s => s.classList.remove('hover'));
      });
    });

    // Bootstrap form validation
    (() => {
      const forms = document.querySelectorAll('.needs-validation');
      forms.forEach(form => {
        form.addEventListener('submit', e => {
          if (!form.checkValidity()) {
            e.preventDefault();
            e.stopPropagation();
          }
          form.classList.add('was-validated');
        });
      });
    })();
  </script>
</body>
</html>
